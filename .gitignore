# ==========================================
# PySide6 / Qt Specific
# ==========================================
# Ignore compiled UI files generated by pyside6-uic
# (Keep your .ui files, ignore the generated .py files)
*_ui.py
ui_*.py

# Ignore compiled resource files generated by pyside6-rcc
# (Keep your .qrc files, ignore the generated _rc.py files)
*_rc.py
rc_*.py

# Qt Creator project artifacts (if using Qt Creator alongside Python)
*.user
*.user.*

# ==========================================
# Application Bundling & Deployment (PyInstaller / Nuitka)
# ==========================================
# PyInstaller specific outputs
*.manifest
*.spec

# Build directories for frozen executables
build/
dist/
main.dist/
main.build/

# ==========================================
# Core Python Exclusions
# ==========================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual Environments
.venv/
venv/
ENV/
env/

# Packaging and Distributions
.eggs/
.installed.cfg
*.egg-info/
*.egg
MANIFEST

# ==========================================
# IDEs and Code Editors
# ==========================================
# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

# PyCharm / IntelliJ
.idea/

# ==========================================
# Testing and Logs
# ==========================================
.pytest_cache/
.coverage
htmlcov/
*.log


## ==== ME === ##
archive/